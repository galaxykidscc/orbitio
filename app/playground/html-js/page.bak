"use client";

import { useMemo, useState } from "react";
import Editor from "@monaco-editor/react";

const starterHtml = `<h1>Hello world</h1>
<p>Edit the code and click Run.</p>
<button id="btn">Click me</button>`;

const starterCss = `body {
  font-family: Arial, sans-serif;
  padding: 16px;
}

h1 {
  color: #4c077c;
}

button {
  padding: 10px 14px;
  border: none;
  border-radius: 8px;
  background: #e0415f;
  color: white;
  cursor: pointer;
}`;
/* alterate starter code if allowing alerts; recommended to disable
const starterJs = `document.getElementById("btn")?.addEventListener("click", () => {
  alert("Nice job! Your JavaScript is working.");
});`;
*/
const starterJs = `document.getElementById("btn")?.addEventListener("click", () => {
  const p = document.createElement("p");
  p.textContent = "Nice job! Your JavaScript is working.";
  document.body.appendChild(p);
});`;

export default function HtmlJsPlayground() {
  const [html, setHtml] = useState(starterHtml);
  const [css, setCss] = useState(starterCss);
  const [js, setJs] = useState(starterJs);

  const [runCode, setRunCode] = useState({
    html: starterHtml,
    css: starterCss,
    js: starterJs,
  });

  const srcDoc = useMemo(() => {
    return `
      <!DOCTYPE html>
      <html>
        <head>
          <style>${runCode.css}</style>
        </head>
        <body>
          ${runCode.html}
          <script>
            window.onerror = function(message) {
              const pre = document.createElement("pre");
              pre.style.color = "red";
              pre.textContent = "JavaScript Error: " + message;
              document.body.appendChild(pre);
            };
          </script>
          <script>${runCode.js}<\/script>
        </body>
      </html>
    `;
  }, [runCode]);

  const handleRun = () => {
    setRunCode({
      html,
      css,
      js,
    });
  };

  const handleReset = () => {
    setHtml(starterHtml);
    setCss(starterCss);
    setJs(starterJs);

    setRunCode({
      html: starterHtml,
      css: starterCss,
      js: starterJs,
    });
  };

  return (
    <main style={{ padding: "24px" }}>
      <h1 style={{ marginBottom: "8px" }}>HTML / JavaScript Playground</h1>
      <p style={{ marginBottom: "16px", color: "#444" }}>
        Write code on the left and preview it on the right.
      </p>

      <div style={{ display: "flex", gap: "12px", marginBottom: "16px" }}>
        <button
          onClick={handleRun}
          style={{
            padding: "10px 16px",
            background: "#4c077c",
            color: "white",
            border: "none",
            borderRadius: "8px",
            cursor: "pointer",
            fontWeight: 600,
          }}
        >
          Run
        </button>

        <button
          onClick={handleReset}
          style={{
            padding: "10px 16px",
            background: "#e5e7eb",
            color: "#111827",
            border: "none",
            borderRadius: "8px",
            cursor: "pointer",
            fontWeight: 600,
          }}
        >
          Reset
        </button>
      </div>

      <div
        style={{
          display: "grid",
          gridTemplateColumns: "1fr 1fr",
          gap: "20px",
          alignItems: "start",
        }}
      >
        <div>
          <h3>HTML</h3>
          <Editor
            height="180px"
            language="html"
            value={html}
            onChange={(value) => setHtml(value || "")}
            theme="vs-dark"
            options={{
              minimap: { enabled: false },
              fontSize: 14,
              scrollBeyondLastLine: false,
              automaticLayout: true,
              wordWrap: "on",
            }}
          />

          <h3 style={{ marginTop: "16px" }}>CSS</h3>
          <Editor
            height="180px"
            language="css"
            value={css}
            onChange={(value) => setCss(value || "")}
            theme="vs-dark"
            options={{
              minimap: { enabled: false },
              fontSize: 14,
              scrollBeyondLastLine: false,
              automaticLayout: true,
              wordWrap: "on",
            }}
          />

          <h3 style={{ marginTop: "16px" }}>JavaScript</h3>
          <Editor
            height="180px"
            language="javascript"
            value={js}
            onChange={(value) => setJs(value || "")}
            theme="vs-dark"
            options={{
              minimap: { enabled: false },
              fontSize: 14,
              scrollBeyondLastLine: false,
              automaticLayout: true,
              wordWrap: "on",
            }}
          />
        </div>

        <div>
          <h3>Preview</h3>
          <iframe
            title="Preview"
            srcDoc={srcDoc}
            sandbox="allow-scripts" //sandbox="allow-scripts allow-modals" -- use to allow alerts
            style={{
              width: "100%",
              height: "620px",
              border: "1px solid #d1d5db",
              borderRadius: "8px",
              background: "white",
            }}
          />
        </div>
      </div>
    </main>
  );
}